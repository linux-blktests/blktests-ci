        </mxCell>

        <!-- ── Physical Nodes ── -->
        <mxCell id="nodes" value="&lt;b&gt;Bare Metal Nodes&lt;/b&gt; (Dell R6525, Ubuntu 22.04) — PCIe NVMe SSDs bound to vfio-pci driver for VM passthrough" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;verticalAlign=middle;align=center;" vertex="1" parent="k3s">
          <mxGeometry x="20" y="760" width="1280" height="60" as="geometry" />
        </mxCell>

        <!-- ───────────── Edges ───────────── -->
        <!-- External → cluster -->
        <mxCell id="e1" value="monitors patches" style="endArrow=classic;html=1;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="patchwork" target="kpd">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="creates PR with patch to test" style="endArrow=classic;html=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="kpd" target="lb-repo">
