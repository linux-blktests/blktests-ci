        </mxCell>
        <mxCell id="e4" value="scheduled workflow trigger" style="endArrow=classic;html=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="nc-repo" target="nc-listener">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

