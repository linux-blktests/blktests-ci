<mxfile host="app.diagrams.net" type="device">
  <diagram name="Architecture" id="blktests-ci-arch">
    <mxGraphModel dx="1600" dy="1000" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ───────────── External Services ───────────── -->
        <mxCell id="patchwork" value="&lt;b&gt;Patchwork&lt;/b&gt;&lt;br&gt;(linux-block mailing list)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=middle;align=center;" vertex="1" parent="1">
