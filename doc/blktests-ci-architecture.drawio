        </mxCell>
        <mxCell id="e12" value="fetches kernel image" style="endArrow=classic;html=1;dashed=1;labelBackgroundColor=#ffffff;exitX=1;exitY=0.8;entryX=0.25;entryY=0;" edge="1" parent="1" source="lb-vm" target="registry">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e13" value="fetches kernel image" style="endArrow=classic;html=1;dashed=1;labelBackgroundColor=#ffffff;exitX=0;exitY=0.8;entryX=0.75;entryY=0;" edge="1" parent="1" source="nc-vm" target="registry">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e14" value="pushes" style="endArrow=classic;html=1;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="kb-cron" target="registry">
