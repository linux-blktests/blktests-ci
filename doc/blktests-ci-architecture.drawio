        <mxCell id="registry" value="Private Container Registry" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=middle;align=center;" vertex="1" parent="reg-ns">
          <mxGeometry x="20" y="40" width="380" height="40" as="geometry" />
