        <!-- Registry interactions. Route the lb-runner push edge around
             the lb-ns container so the label and arrow don't overlap
             the kubevirt-action / KubeVirt VM boxes. -->
        <mxCell id="e11" value="pushes container image (kernel + initramfs)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;labelBackgroundColor=#ffffff;exitX=0;exitY=0.5;entryX=0.05;entryY=0;jettySize=auto;orthogonalLoop=1;" edge="1" parent="1" source="lb-runner" target="registry">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="68" y="430" />
              <mxPoint x="68" y="655" />
              <mxPoint x="520" y="655" />
            </Array>
