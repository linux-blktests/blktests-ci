# Service account used by the GitLab CI job pods (set via the Kubernetes
# executor `service_account` setting). It grants the job pod permission to
# create and manage the KubeVirt VMs that actually run the kernel workload.
# This is the GitLab counterpart of the identically named service account used
# by the GitHub ARC runner pods.
apiVersion: v1
kind: ServiceAccount
metadata:
  name: kubevirt-actions-runner
  namespace: "gl-runner-{{ runner_set_name }}"
---
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: kubevirt-actions-runner
  namespace: "gl-runner-{{ runner_set_name }}"
rules:
  - apiGroups: ["kubevirt.io"]
    resources: ["virtualmachines"]
    verbs: ["get", "watch", "list", "create", "delete"]
  - apiGroups: ["kubevirt.io"]
    resources: ["virtualmachineinstances"]
    verbs: ["get", "watch", "list", "create", "delete"]
  - apiGroups: ["subresources.kubevirt.io"]
    resources: ["virtualmachineinstances/portforward", "virtualmachineinstances/console"]
    verbs: ["get"]
  - apiGroups: [""]
    resources: ["events", "pods"]
    verbs: ["get", "list", "watch"]
  - apiGroups: [""]
    resources: ["configmaps"]
    verbs: ["get", "list", "watch", "create", "delete"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: kubevirt-actions-runner
  namespace: "gl-runner-{{ runner_set_name }}"
subjects:
  - kind: ServiceAccount
    name: kubevirt-actions-runner
    namespace: "gl-runner-{{ runner_set_name }}"
roleRef:
  kind: Role
  name: kubevirt-actions-runner
  apiGroup: rbac.authorization.k8s.io
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: kubevirt-actions-runner-node-reader-gl-{{ runner_set_name }}
rules:
  - apiGroups: [""]
    resources: ["nodes"]
    verbs: ["get", "list"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: kubevirt-actions-runner-node-reader-gl-{{ runner_set_name }}
subjects:
  - kind: ServiceAccount
    name: kubevirt-actions-runner
    namespace: "gl-runner-{{ runner_set_name }}"
roleRef:
  kind: ClusterRole
  name: kubevirt-actions-runner-node-reader-gl-{{ runner_set_name }}
  apiGroup: rbac.authorization.k8s.io
