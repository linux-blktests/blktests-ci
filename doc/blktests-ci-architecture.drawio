        <mxCell id="mitmproxy" value="mitmproxy (optional)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=middle;align=center;" vertex="1" parent="infra">
