        <mxCell id="lb-repo" value="&lt;b&gt;linux-block&lt;/b&gt;&lt;br&gt;GitHub repo" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=middle;align=center;" vertex="1" parent="1">
