        <mxCell id="nc-repo" value="&lt;b&gt;nvme-cli&lt;/b&gt;&lt;br&gt;GitHub repo" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=middle;align=center;" vertex="1" parent="1">
