apiVersion: kubevirt.io/v1
kind: VirtualMachine
metadata:
  name: {{ vm_name }}
spec:
  runStrategy: Always
  template:
    metadata:
      name: runner
    spec:
      architecture: amd64
      terminationGracePeriodSeconds: 30
      domain:
{% if (kernel_version is defined and kernel_version) or host_devices %}
        firmware:
{% if kernel_version is defined and kernel_version %}
          kernelBoot:
            container:
              image: container-registry.local:5000/linux-kernel-containerdisk:{{ kernel_version }}
              initrdPath: /boot/initramfs-{{ kernel_version }}.img
              kernelPath: /boot/vmlinux-{{ kernel_version }}
              imagePullPolicy: Always
            kernelArgs: "loglevel=7 no_timer_check console=tty1 console=ttyS0,115200n8 systemd=off root=/dev/vda4 rootflags=subvol=root"
{% endif %}
{% if host_devices %}
          # A passed-through PCI device such as a SAS HBA carries a legacy
          # option ROM that the default SeaBIOS firmware executes during POST.
          # The LSI SAS ROM hangs there, so the guest never reaches the kernel
          # (empty serial console, and ssh fails with "no route to host"). Boot
          # via EFI/OVMF instead, which does not run the legacy option ROM.
          # Scoped to host-device VMs so plain VMs keep the default firmware.
          bootloader:
            efi:
              secureBoot: false
{% endif %}
{% endif %}
        devices:
          filesystems:
            - name: prepare-nvme-devices
              virtiofs: {}
            - name: vm-init
              virtiofs: {}
          disks:
            - name: containerdisk
              disk:
                bus: virtio
            - name: cloudinitdisk
              disk:
                bus: virtio
{% if kernel_version is defined and kernel_version %}
            - name: kernel-modules
              cdrom:
                bus: sata
{% endif %}
          interfaces:
            - name: default
              masquerade: {}
{% if host_devices %}
          hostDevices:
{% for dev in host_devices %}
            - name: {{ dev.name }}
              deviceName: {{ dev.deviceName }}
{% endfor %}
{% endif %}
        cpu:
          cores: 4
        resources:
          requests:
            memory: 8Gi
      networks:
        - name: default
          pod: {}
      volumes:
        - name: containerdisk
          containerDisk:
            image: {{ container_disk_image | default('quay.io/containerdisks/fedora:42', true) }}
{% if kernel_version is defined and kernel_version %}
        - name: kernel-modules
          containerDisk:
            image: container-registry.local:5000/linux-kernel-containerdisk:{{ kernel_version }}
            path: /boot/kernel-modules.isofs
            imagePullPolicy: Always
{% endif %}
        - name: prepare-nvme-devices
          configMap:
            name: prepare-nvme-devices
        - name: vm-init
          configMap:
            name: {{ vm_name }}-cloud-init
        - name: cloudinitdisk
          cloudInitNoCloud:
            userData: |
              #cloud-config
              users:
                - name: fedora
                  sudo: ["ALL=(ALL) NOPASSWD:ALL"]
                  groups: users, admin, docker, podman
                  ssh_authorized_keys:
                    - {{ vm_ssh_authorized_keys }}
              runcmd:
                - "mkdir -p /mnt/vm-init"
                - "mount -t virtiofs vm-init /mnt/vm-init"
                - "bash /mnt/vm-init/init.sh"