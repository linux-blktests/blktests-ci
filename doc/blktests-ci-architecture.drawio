        <mxCell id="kb-cron" value="kernel-builder CronJob (nightly)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=middle;align=center;" vertex="1" parent="kb-ns">
          <mxGeometry x="20" y="40" width="380" height="40" as="geometry" />
