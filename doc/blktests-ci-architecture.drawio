        <!-- ── kernel-builder namespace ── -->
        <mxCell id="kb-ns" value="gh-runner-kernel-builder namespace" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#666666;dashed=1;verticalAlign=top;align=left;fontStyle=2;container=1;collapsible=0;spacingLeft=8;spacingTop=4;" vertex="1" parent="k3s">
          <mxGeometry x="20" y="500" width="420" height="90" as="geometry" />
