        </mxCell>
        <mxCell id="e6" value="spawns" style="endArrow=classic;html=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="nc-listener" target="nc-runner">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Runner -> kva -> vm (internal dashed) -->
        <mxCell id="e7" style="endArrow=classic;html=1;dashed=1;" edge="1" parent="1" source="lb-runner" target="lb-kva">
