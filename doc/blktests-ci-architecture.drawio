        </mxCell>
        <mxCell id="nc-vm" value="&lt;b&gt;Ephemeral KubeVirt VM&lt;/b&gt;&lt;br&gt;1. Boots Fedora cloud image with nightly built kernel&lt;br&gt;2. Runs nvme-cli tests on PCIe passthrough NVMe SSDs via SSH" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=middle;align=center;" vertex="1" parent="nc-ns">
